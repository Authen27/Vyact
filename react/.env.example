# FinFlow v4.1 — Cloud configuration
#
# Copy this file to `.env.local` and fill in your Supabase credentials.
# The app boots in LocalStorage-only "anonymous mode" if these are unset
# — every existing v6/v7 feature still works without a backend.

# Your Supabase project URL.
# Find it in: https://app.supabase.com → Project → Settings → API → Project URL
VITE_SUPABASE_URL=

# Your Supabase anon (public) key — safe to ship to the browser.
# Find it in: https://app.supabase.com → Project → Settings → API → anon / public
VITE_SUPABASE_ANON_KEY=

# Optional — base URL the app is hosted at (used in invitation emails).
# Defaults to window.location.origin.
VITE_APP_URL=
